generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model activity_logs {
  id         String   @id
  orderId    String
  actorId    String?
  action     String
  details    Json?
  createdAt  DateTime @default(now())
  actorEmail String?
  entityType String   @default("order")
  fieldName  String?
  oldValue   String?
  newValue   String?
  notes      String?
  ipAddress  String?
  userAgent  String?
  users      users?   @relation(fields: [actorId], references: [id])
  orders     orders   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([entityType, createdAt])
  @@index([orderId])
}

model customers {
  id         String   @id
  shopifyId  String?  @unique
  email      String   @unique
  firstName  String?
  lastName   String?
  phone      String?
  address    String?
  city       String?
  postalCode String?
  country    String?
  hubspotId  String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  orders     orders[]
}

model deliveries {
  id                    String    @id
  orderId               String    @unique
  assignedToId          String?
  assignedAt            DateTime?
  deliveryAddress       String
  deliveryNotes         String?
  signatureUrl          String?
  photoUrl              String?
  deliveredAt           DateTime?
  latitude              Float?
  longitude             Float?
  deliveryNotesInternal String?
  failedReason          String?
  hubspotSynced         Boolean   @default(false)
  hubspotSyncAt         DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime
  users                 users?    @relation(fields: [assignedToId], references: [id])
  orders                orders    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([assignedToId])
  @@index([deliveredAt])
  @@index([hubspotSynced])
  @@index([orderId])
}

model inventory {
  id              String     @id(map: "inventory_new_pkey") @default(dbgenerated("gen_random_uuid()"))
  productId       String
  locationId      String?
  currentStock    Int?       @default(0)
  reserved        Int?       @default(0)
  available       Int?       @default(0)
  reorderPoint    Int?
  reorderQty      Int?
  reorderLeadTime Int?       @default(7)
  lastCountedAt   DateTime?  @db.Timestamp(6)
  lastMovementAt  DateTime?  @db.Timestamp(6)
  locations       locations? @relation(fields: [locationId], references: [id], map: "inventory_locationid_fkey")
  products        products   @relation(fields: [productId], references: [id], map: "inventory_productid_fkey")

  @@unique([productId, locationId], map: "inventory_new_productId_locationId_key")
  @@index([locationId], map: "inventory_locationid_idx")
  @@index([productId], map: "inventory_productid_idx")
}

model locations {
  id        String      @id @default(dbgenerated("gen_random_uuid()"))
  code      String      @unique
  name      String
  type      String?     @default("warehouse")
  isactive  Boolean?    @default(true)
  address   String?
  inventory inventory[]
}

model orders {
  id                 String            @id
  shopifyId          String            @unique
  shopifyOrderNumber String?
  customerId         String
  totalAmount        Decimal           @db.Decimal(10, 2)
  currency           String            @default("USD")
  lineItems          Json
  status             OrderStatus       @default(RECEIVED)
  shopifySyncStatus  ShopifySyncStatus @default(PENDING)
  shopifyUpdatedAt   DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime
  hubspotSyncAt      DateTime?
  hubspotSynced      Boolean           @default(false)
  activity_logs      activity_logs[]
  deliveries         deliveries?
  customers          customers         @relation(fields: [customerId], references: [id])

  @@index([createdAt])
  @@index([customerId])
  @@index([hubspotSynced])
  @@index([shopifyId])
  @@index([status])
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

model products {
  id        String      @id @default(dbgenerated("gen_random_uuid()"))
  sku       String      @unique
  name      String
  basePrice Decimal?    @default(0) @db.Decimal(10, 2)
  inventory inventory[]
}

model test_table {
  id String @id
}

model users {
  id            String          @id
  email         String          @unique
  name          String?
  role          UserRole        @default(OPERATOR)
  password      String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  isActive      Boolean         @default(true)
  activity_logs activity_logs[]
  deliveries    deliveries[]
}

model webhook_events {
  id          String    @id
  shopifyId   String    @unique
  topic       String
  payload     Json
  processed   Boolean   @default(false)
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  @@index([processed])
}

enum OrderStatus {
  RECEIVED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

enum ShopifySyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum UserRole {
  ADMIN
  OPERATOR
  DRIVER
}
