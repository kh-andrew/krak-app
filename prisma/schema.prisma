generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Batch {
  id             String    @id @default(dbgenerated("gen_random_uuid()"))
  batchCode      String    @unique
  productId      String
  locationId     String?
  manufacturedAt DateTime? @db.Timestamp(6)
  expiryDate     DateTime? @db.Timestamp(6)
  initialQty     Int
  remainingQty   Int
  status         String?   @default("active")
  createdAt      DateTime? @default(now()) @db.Timestamp(6)
  Location       Location? @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Product        Product   @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([productId], map: "idx_batch_product")
}

model BundleComponent {
  id                                         String    @id @default(dbgenerated("gen_random_uuid()"))
  parentSku                                  String
  childSku                                   String
  quantity                                   Int
  version                                    String?   @default("v1")
  effectiveFrom                              DateTime? @default(now()) @db.Timestamp(6)
  effectiveTo                                DateTime? @db.Timestamp(6)
  isActive                                   Boolean?  @default(true)
  createdAt                                  DateTime? @default(now()) @db.Timestamp(6)
  Product_BundleComponent_childSkuToProduct  Product   @relation("BundleComponent_childSkuToProduct", fields: [childSku], references: [sku], onDelete: NoAction, onUpdate: NoAction)
  Product_BundleComponent_parentSkuToProduct Product   @relation("BundleComponent_parentSkuToProduct", fields: [parentSku], references: [sku], onDelete: NoAction, onUpdate: NoAction)

  @@unique([parentSku, childSku, version])
  @@index([parentSku, isActive], map: "idx_bundle_parent")
  @@index([parentSku, version], map: "idx_bundle_version")
}

model DemandForecast {
  id                  String    @id @default(dbgenerated("gen_random_uuid()"))
  productId           String
  avgDailySales       Decimal?  @db.Decimal(10, 2)
  daysUntilStockout   Int?
  suggestedReorderQty Int?
  confidence          Decimal?  @db.Decimal(3, 2)
  calculatedAt        DateTime? @default(now()) @db.Timestamp(6)
  validUntil          DateTime? @db.Timestamp(6)
  Product             Product   @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([productId, calculatedAt])
}

model Inventory {
  id                String              @id @default(dbgenerated("gen_random_uuid()"))
  productId         String
  locationId        String?
  currentStock      Int?                @default(0)
  reserved          Int?                @default(0)
  available         Int?                @default(0)
  reorderPoint      Int?
  reorderQty        Int?
  reorderLeadTime   Int?                @default(7)
  lastCountedAt     DateTime?           @db.Timestamp(6)
  lastMovementAt    DateTime?           @db.Timestamp(6)
  Location          Location?           @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Product           Product             @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  InventoryMovement InventoryMovement[]

  @@unique([productId, locationId])
  @@index([locationId], map: "idx_inventory_location")
  @@index([productId], map: "idx_inventory_product")
}

model InventoryMovement {
  id              String    @id @default(dbgenerated("gen_random_uuid()"))
  inventoryId     String
  type            String
  quantity        Int
  reason          String?
  orderId         String?
  batchId         String?
  sourceSku       String?
  targetSku       String?
  conversionRatio Int?
  performedBy     String?
  notes           String?
  createdAt       DateTime? @default(now()) @db.Timestamp(6)
  Inventory       Inventory @relation(fields: [inventoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([createdAt], map: "idx_movement_created")
  @@index([inventoryId], map: "idx_movement_inventory")
}

model Location {
  id        String      @id @default(dbgenerated("gen_random_uuid()"))
  code      String      @unique
  name      String
  type      String      @default("warehouse")
  address   String?
  isActive  Boolean?    @default(true)
  Batch     Batch[]
  Inventory Inventory[]
}

model Product {
  id                                                 String              @id @default(dbgenerated("gen_random_uuid()"))
  sku                                                String              @unique
  name                                               String
  description                                        String?
  category                                           String              @default("beverage")
  subcategory                                        String?
  brand                                              String?             @default("krak")
  unitWeight                                         Decimal?            @db.Decimal(10, 2)
  unitVolume                                         Int?
  basePrice                                          Decimal             @db.Decimal(10, 2)
  costPrice                                          Decimal?            @db.Decimal(10, 2)
  currency                                           String?             @default("USD")
  isBundle                                           Boolean?            @default(false)
  bundleComponents                                   Json?               @default("[]")
  componentOf                                        Json?               @default("[]")
  isActive                                           Boolean?            @default(true)
  createdAt                                          DateTime?           @default(now()) @db.Timestamp(6)
  updatedAt                                          DateTime?           @default(now()) @db.Timestamp(6)
  Batch                                              Batch[]
  BundleComponent_BundleComponent_childSkuToProduct  BundleComponent[]   @relation("BundleComponent_childSkuToProduct")
  BundleComponent_BundleComponent_parentSkuToProduct BundleComponent[]   @relation("BundleComponent_parentSkuToProduct")
  DemandForecast                                     DemandForecast[]
  Inventory                                          Inventory[]
  PurchaseOrderItem                                  PurchaseOrderItem[]

  @@index([isActive], map: "idx_product_active")
  @@index([sku], map: "idx_product_sku")
}

model PurchaseOrder {
  id                String              @id @default(dbgenerated("gen_random_uuid()"))
  poNumber          String              @unique
  supplier          String?
  status            String?             @default("draft")
  totalItems        Int?                @default(0)
  totalQty          Int?                @default(0)
  totalValue        Decimal?            @db.Decimal(12, 2)
  expectedDelivery  DateTime?           @db.Timestamp(6)
  receivedAt        DateTime?           @db.Timestamp(6)
  notes             String?
  createdBy         String?
  createdAt         DateTime?           @default(now()) @db.Timestamp(6)
  updatedAt         DateTime?           @default(now()) @db.Timestamp(6)
  PurchaseOrderItem PurchaseOrderItem[]

  @@index([status], map: "idx_po_status")
}

model PurchaseOrderItem {
  id            String        @id @default(dbgenerated("gen_random_uuid()"))
  poId          String
  productId     String
  orderedQty    Int
  receivedQty   Int?          @default(0)
  unitCost      Decimal?      @db.Decimal(10, 2)
  PurchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Product       Product       @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([poId, productId])
}

model activity_logs {
  id         String   @id
  orderId    String
  actorId    String?
  action     String
  details    Json?
  createdAt  DateTime @default(now())
  actorEmail String?
  entityType String   @default("order")
  fieldName  String?
  oldValue   String?
  newValue   String?
  notes      String?
  ipAddress  String?
  userAgent  String?
  users      users?   @relation(fields: [actorId], references: [id])
  orders     orders   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([entityType, createdAt])
  @@index([orderId])
}

model customers {
  id         String   @id
  shopifyId  String?  @unique
  email      String   @unique
  firstName  String?
  lastName   String?
  phone      String?
  address    String?
  city       String?
  postalCode String?
  country    String?
  hubspotId  String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  orders     orders[]
}

model deliveries {
  id                    String    @id
  orderId               String    @unique
  assignedToId          String?
  assignedAt            DateTime?
  deliveryAddress       String
  deliveryNotes         String?
  signatureUrl          String?
  photoUrl              String?
  deliveredAt           DateTime?
  latitude              Float?
  longitude             Float?
  deliveryNotesInternal String?
  failedReason          String?
  hubspotSynced         Boolean   @default(false)
  hubspotSyncAt         DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime
  users                 users?    @relation(fields: [assignedToId], references: [id])
  orders                orders    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([assignedToId])
  @@index([deliveredAt])
  @@index([hubspotSynced])
  @@index([orderId])
}

model inventory {
  id              String   @id
  sku             String   @unique
  name            String
  currentStock    Int      @default(0)
  reserved        Int      @default(0)
  available       Int      @default(0)
  reorderPoint    Int?
  reorderQty      Int?
  lastAgentAction String?
  agentConfidence Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime

  @@index([available])
  @@index([sku])
}

model locations {
  id       String   @id @default(dbgenerated("gen_random_uuid()"))
  code     String   @unique
  name     String
  type     String?  @default("warehouse")
  isactive Boolean? @default(true)
  address  String?
}

model orders {
  id                 String            @id
  shopifyId          String            @unique
  shopifyOrderNumber String?
  customerId         String
  totalAmount        Decimal           @db.Decimal(10, 2)
  currency           String            @default("USD")
  lineItems          Json
  status             OrderStatus       @default(RECEIVED)
  shopifySyncStatus  ShopifySyncStatus @default(PENDING)
  shopifyUpdatedAt   DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime
  hubspotSyncAt      DateTime?
  hubspotSynced      Boolean           @default(false)
  activity_logs      activity_logs[]
  deliveries         deliveries?
  customers          customers         @relation(fields: [customerId], references: [id])

  @@index([createdAt])
  @@index([customerId])
  @@index([hubspotSynced])
  @@index([shopifyId])
  @@index([status])
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

model products {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  sku       String   @unique
  name      String
  basePrice Decimal? @default(0) @db.Decimal(10, 2)
}

model test_table {
  id String @id
}

model users {
  id            String          @id
  email         String          @unique
  name          String?
  role          UserRole        @default(OPERATOR)
  password      String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  isActive      Boolean         @default(true)
  activity_logs activity_logs[]
  deliveries    deliveries[]
}

model webhook_events {
  id          String    @id
  shopifyId   String    @unique
  topic       String
  payload     Json
  processed   Boolean   @default(false)
  processedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  @@index([processed])
}

enum OrderStatus {
  RECEIVED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

enum ShopifySyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum UserRole {
  ADMIN
  OPERATOR
  DRIVER
}
