// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User roles for team access
enum UserRole {
  ADMIN
  OPERATOR
  DRIVER
}

// Order status flow
enum OrderStatus {
  RECEIVED      // Order from Shopify received
  PREPARING     // Being prepared for delivery
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED        // Delivery attempt failed
}

// Shopify sync status
enum ShopifySyncStatus {
  PENDING
  SYNCED
  FAILED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          UserRole  @default(OPERATOR)
  password      String    // Hashed
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isActive      Boolean   @default(true)
  
  // Relations
  assignedDeliveries Delivery[]
  activityLogs       ActivityLog[]
  
  @@map("users")
}

model Customer {
  id          String   @id @default(cuid())
  shopifyId   String?  @unique
  email       String   @unique
  firstName   String?
  lastName    String?
  phone       String?
  address     String?
  city        String?
  postalCode  String?
  country     String?
  hubspotId   String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  orders Order[]
  
  @@map("customers")
}

model Order {
  id                String            @id @default(cuid())
  shopifyId         String            @unique
  shopifyOrderNumber String?
  
  // Customer info
  customerId        String
  customer          Customer          @relation(fields: [customerId], references: [id])
  
  // Order details
  totalAmount       Decimal           @db.Decimal(10, 2)
  currency          String            @default("USD")
  lineItems         Json              // Array of { title, quantity, price, sku }
  
  // Status
  status            OrderStatus       @default(RECEIVED)
  shopifySyncStatus ShopifySyncStatus @default(PENDING)
  
  // Shopify sync timestamps
  shopifyUpdatedAt  DateTime?
  
  // HubSpot sync
  hubspotSynced     Boolean           @default(false)
  hubspotSyncAt     DateTime?
  
  // Relations
  delivery          Delivery?
  activityLogs      ActivityLog[]
  
  // Timestamps
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  // Indexes for performance at scale
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([shopifyId])
  @@index([hubspotSynced])
  
  @@map("orders")
}

model Delivery {
  id              String    @id @default(cuid())
  orderId         String    @unique
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // Assignment
  assignedToId    String?
  assignedTo      User?     @relation(fields: [assignedToId], references: [id])
  assignedAt      DateTime?
  
  // Delivery details
  deliveryAddress String
  deliveryNotes   String?
  
  // Proof of delivery
  signatureUrl    String?   // Cloudinary URL
  photoUrl        String?   // Cloudinary URL
  deliveredAt     DateTime?
  
  // Geolocation
  latitude        Float?
  longitude       Float?
  
  // Delivery attempt
  deliveryNotesInternal String?
  failedReason    String?
  
  // HubSpot sync
  hubspotSynced   Boolean   @default(false)
  hubspotSyncAt   DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Indexes for performance at scale
  @@index([orderId])
  @@index([assignedToId])
  @@index([deliveredAt])
  @@index([hubspotSynced])
  
  @@map("deliveries")
}

model ActivityLog {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
  actorEmail  String?  // Denormalized for audit trail integrity
  
  action      String   // ENUM: status_changed, assigned, delivered, note_added, etc.
  
  // Lean change tracking (no JSON blob)
  entityType  String   // "order", "delivery", "inventory"
  fieldName   String?  // "status", "assignedToId", etc.
  oldValue    String?  // Previous value (stringified)
  newValue    String?  // New value (stringified)
  notes       String?  // Human-readable context
  
  // Audit metadata
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
  
  @@index([orderId, createdAt])
  @@index([entityType, createdAt])
  @@index([createdAt])
  @@map("activity_logs")
}

// Webhook events from Shopify for processing
model WebhookEvent {
  id          String   @id @default(cuid())
  shopifyId   String   // Unique webhook ID from Shopify
  topic       String   // e.g., "orders/create", "orders/updated"
  payload     Json     // Full webhook payload
  processed   Boolean  @default(false)
  processedAt DateTime?
  error       String?
  
  createdAt   DateTime @default(now())
  
  @@unique([shopifyId])
  @@index([processed])
  @@map("webhook_events")
}

// Inventory tracking for Demand Planner Agent
model Inventory {
  id            String   @id @default(cuid())
  sku           String   @unique
  
  // Product info
  name          String
  category      String?  // UDT, 3DH, OHL, etc.
  productLine   String?  // Lipstick, Lip Oil, Blush, etc.
  variant       String?  // Shade/color code
  size          String?  // REG, MIN, SET, etc.
  
  // Stock levels (aggregated across all batches)
  currentStock  Int      @default(0)
  reserved      Int      @default(0)
  available     Int      @default(0)
  
  // Reorder logic
  reorderPoint  Int?
  reorderQty    Int?
  leadTimeDays  Int?     // Days from order to delivery
  
  // Agent tracking
  lastAgentAction String?
  agentConfidence Float?
  
  // Relations
  batches       InventoryBatch[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([sku])
  @@index([category])
  @@index([available])
  @@map("inventory")
}

// Batch tracking for traceability and recalls
model InventoryBatch {
  id            String   @id @default(cuid())
  
  // Relations
  inventoryId   String
  inventory     Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  
  // Batch identification
  batchNumber   String   // Manufacturer batch code
  internalCode  String?  // Your internal tracking code
  
  // Batch details
  quantity      Int
  quantityUsed  Int      @default(0)
  quantityAvailable Int  @default(0)
  
  // Dates
  manufacturedAt DateTime?
  receivedAt    DateTime @default(now())
  expiresAt     DateTime? // For products with shelf life
  
  // Quality/Recall
  status        String   @default("ACTIVE") // ACTIVE, QUARANTINE, RECALLED, EXPIRED
  qualityNotes  String?
  recallReason  String?
  
  // Traceability
  supplier      String?
  poNumber      String?  // Purchase order reference
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([inventoryId])
  @@index([batchNumber])
  @@index([status])
  @@index([expiresAt])
  @@map("inventory_batches")
}