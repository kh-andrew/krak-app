// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User roles for team access
enum UserRole {
  ADMIN
  OPERATOR
  DRIVER
}

// Order status flow
enum OrderStatus {
  RECEIVED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
}

// Shopify sync status
enum ShopifySyncStatus {
  PENDING
  SYNCED
  FAILED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          UserRole  @default(OPERATOR)
  password      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  isActive      Boolean   @default(true)
  
  assignedDeliveries Delivery[]
  activityLogs       ActivityLog[]
  
  @@map("users")
}

model Customer {
  id          String   @id @default(cuid())
  shopifyId   String?  @unique
  email       String   @unique
  firstName   String?
  lastName    String?
  phone       String?
  address     String?
  city        String?
  postalCode  String?
  country     String?
  hubspotId   String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  orders Order[]
  
  @@map("customers")
}

model Order {
  id                String            @id @default(cuid())
  shopifyId         String            @unique
  shopifyOrderNumber String?
  
  customerId        String
  customer          Customer          @relation(fields: [customerId], references: [id])
  
  totalAmount       Decimal           @db.Decimal(10, 2)
  currency          String            @default("USD")
  lineItems         Json
  
  status            OrderStatus       @default(RECEIVED)
  shopifySyncStatus ShopifySyncStatus @default(PENDING)
  
  shopifyUpdatedAt  DateTime?
  
  hubspotSynced     Boolean           @default(false)
  hubspotSyncAt     DateTime?
  
  delivery          Delivery?
  activityLogs      ActivityLog[]
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([shopifyId])
  @@index([hubspotSynced])
  
  @@map("orders")
}

model Delivery {
  id              String    @id @default(cuid())
  orderId         String    @unique
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  assignedToId    String?
  assignedTo      User?     @relation(fields: [assignedToId], references: [id])
  assignedAt      DateTime?
  
  deliveryAddress String
  deliveryNotes   String?
  
  signatureUrl    String?
  photoUrl        String?
  deliveredAt     DateTime?
  
  latitude        Float?
  longitude       Float?
  
  deliveryNotesInternal String?
  failedReason    String?
  
  hubspotSynced   Boolean   @default(false)
  hubspotSyncAt   DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([orderId])
  @@index([assignedToId])
  @@index([deliveredAt])
  @@index([hubspotSynced])
  
  @@map("deliveries")
}

model ActivityLog {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
  actorEmail  String?
  
  action      String
  
  entityType  String
  fieldName   String?
  oldValue    String?
  newValue    String?
  notes       String?
  
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
  
  @@index([orderId, createdAt])
  @@index([entityType, createdAt])
  @@index([createdAt])
  @@map("activity_logs")
}

model WebhookEvent {
  id          String   @id @default(cuid())
  shopifyId   String
  topic       String
  payload     Json
  processed   Boolean  @default(false)
  processedAt DateTime?
  error       String?
  
  createdAt   DateTime @default(now())
  
  @@unique([shopifyId])
  @@index([processed])
  @@map("webhook_events")
}

// ============================================
// KRAK INVENTORY SYSTEM (NEW)
// ============================================

model Product {
  id              String   @id @default(cuid())
  sku             String   @unique
  name            String
  description     String?
  
  category        String   @default("beverage")
  subcategory     String?
  brand           String   @default("krak")
  
  unitWeight      Decimal? @db.Decimal(10, 2)
  unitVolume      Int?
  
  basePrice       Decimal  @db.Decimal(10, 2)
  costPrice       Decimal? @db.Decimal(10, 2)
  currency        String   @default("USD")
  
  isBundle        Boolean  @default(false)
  
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  inventoryItems  Inventory[]
  bundleComponents BundleComponent[] @relation("BundleParent")
  componentOf     BundleComponent[] @relation("BundleChild")
  batches         Batch[]
  
  @@map("products")
}

model BundleComponent {
  id            String   @id @default(cuid())
  parentSku     String
  parent        Product  @relation("BundleParent", fields: [parentSku], references: [sku])
  childSku      String
  child         Product  @relation("BundleChild", fields: [childSku], references: [sku])
  quantity      Int
  
  version       String   @default("v1")
  effectiveFrom DateTime @default(now())
  effectiveTo   DateTime?
  isActive      Boolean  @default(true)
  
  createdAt     DateTime @default(now())
  
  @@unique([parentSku, childSku, version])
  @@map("bundle_components")
}

model Location {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  type        String   @default("warehouse")
  address     String?
  isActive    Boolean  @default(true)
  
  inventory   Inventory[]
  batches     Batch[]
  
  @@map("locations")
}

model Inventory {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  locationId      String?
  location        Location? @relation(fields: [locationId], references: [id])
  
  currentStock    Int      @default(0)
  reserved        Int      @default(0)
  available       Int      @default(0)
  
  reorderPoint    Int?
  reorderQty      Int?
  reorderLeadTime Int      @default(7)
  
  lastCountedAt   DateTime?
  lastMovementAt  DateTime?
  
  movements       InventoryMovement[]
  
  @@unique([productId, locationId])
  @@map("inventory")
}

model InventoryMovement {
  id            String   @id @default(cuid())
  inventoryId   String
  inventory     Inventory @relation(fields: [inventoryId], references: [id])
  
  type          String   // 'in', 'out', 'adjustment', 'transfer', 'conversion'
  quantity      Int
  reason        String?  // 'sale', 'receipt', 'damage', 'count', 'bundle_break', 'bundle_create'
  
  orderId       String?
  batchId       String?
  
  sourceSku     String?
  targetSku     String?
  conversionRatio Int?
  
  performedBy   String?
  notes         String?
  createdAt     DateTime @default(now())
  
  @@map("inventory_movements")
}

model Batch {
  id            String   @id @default(cuid())
  batchCode     String   @unique
  productId     String
  product       Product  @relation(fields: [productId], references: [id])
  locationId    String?
  location      Location? @relation(fields: [locationId], references: [id])
  
  manufacturedAt DateTime?
  expiryDate     DateTime?
  
  initialQty     Int
  remainingQty   Int
  
  status         String   @default("active")
  
  createdAt      DateTime @default(now())
  
  @@map("batches")
}

model PurchaseOrder {
  id              String   @id @default(cuid())
  poNumber        String   @unique
  supplier        String?
  status          String   @default("draft")
  
  totalItems      Int      @default(0)
  totalQty        Int      @default(0)
  totalValue      Decimal? @db.Decimal(12, 2)
  
  expectedDelivery DateTime?
  receivedAt      DateTime?
  
  notes           String?
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  items           PurchaseOrderItem[]
  
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id            String   @id @default(cuid())
  poId          String
  po            PurchaseOrder @relation(fields: [poId], references: [id])
  productId     String
  
  orderedQty    Int
  receivedQty   Int      @default(0)
  unitCost      Decimal? @db.Decimal(10, 2)
  
  @@unique([poId, productId])
  @@map("purchase_order_items")
}

model DemandForecast {
  id                  String   @id @default(cuid())
  productId           String
  
  avgDailySales       Decimal? @db.Decimal(10, 2)
  daysUntilStockout   Int?
  suggestedReorderQty Int?
  confidence          Decimal? @db.Decimal(3, 2)
  
  calculatedAt        DateTime @default(now())
  validUntil          DateTime?
  
  @@unique([productId, calculatedAt])
  @@map("demand_forecasts")
}
